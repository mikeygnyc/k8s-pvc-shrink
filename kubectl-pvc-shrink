#!/bin/bash
set -e

# --- 1. Constants & Functions (Defined First) ---
VERSION="v1.1.1"
UPDATE_URL="https://raw.githubusercontent.com/mikeygnyc/k8s-pvc-shrink/main/VERSION"
RAW_SCRIPT_URL="https://raw.githubusercontent.com/mikeygnyc/k8s-pvc-shrink/main/kubectl-pvc-shrink"
TEMP_PVC_NAME="pvc-shrink-temp"
RSYNC_IMAGE="instrumentisto/rsync-ssh"
LOG_DIR="./shrink_logs"

msg() { echo -e "\e[32m[INFO]\e[0m $1"; }
err() { echo -e "\e[31m[ERROR]\e[0m $1"; exit 1; }
highlight() { echo -e "\e[33m$1\e[0m"; }

# NEW: Pre-flight Dependency Check
check_deps() {
    local missing_deps=()
    for dep in kubectl fzf yq column; do
        if ! command -v "$dep" >/dev/null 2>&1; then
            missing_deps+=("$dep")
        fi
    done

    if [ ${#missing_deps[@]} -ne 0 ]; then
        echo -e "\e[31m[!] Missing Dependencies:\e[0m"
        for item in "${missing_deps[@]}"; do
            echo "  - $item"
        done
        echo -e "\nPlease install them using your package manager (e.g., brew install fzf yq)."
        exit 1
    fi
}

check_updates() {
    msg "Checking for updates..."
    local REMOTE_VERSION
    REMOTE_VERSION=$(curl -s --connect-timeout 2 "$UPDATE_URL" || echo "$VERSION")

    if [[ "$REMOTE_VERSION" != "$VERSION" ]]; then
        highlight "✨ A new version ($REMOTE_VERSION) is available! (Current: $VERSION)"
        read -r -p "Update and restart now? (y/n): " UPDATE_NOW
        if [[ "$UPDATE_NOW" == "y" ]]; then
            local SCRIPT_PATH
            SCRIPT_PATH=$(command -v kubectl-pvc-shrink || echo "$0")
            local TEMP_FILE="/tmp/kubectl-pvc-shrink-update"

            msg "Downloading update..."
            if curl -fsSL "$RAW_SCRIPT_URL" -o "$TEMP_FILE"; then
                if [ -w "$SCRIPT_PATH" ]; then
                    mv "$TEMP_FILE" "$SCRIPT_PATH" && chmod +x "$SCRIPT_PATH"
                else
                    sudo mv "$TEMP_FILE" "$SCRIPT_PATH" && sudo chmod +x "$SCRIPT_PATH"
                fi
                msg "Update successful. Restarting..."
                exec "$SCRIPT_PATH" "$@"
            else
                err "Update download failed."
            fi
        fi
        echo "------------------------------------------------"
    fi
}

rollback() {
    echo -e "\n"
    msg "Rolling back..."
    kubectl scale "$TYPE" "$RES_NAME" -n "$NAMESPACE" --replicas="$ORIG_REPLICAS"
    kubectl delete pod shrink-to-temp shrink-back -n "$NAMESPACE" --ignore-not-found
    kubectl delete pvc "$TEMP_PVC_NAME" -n "$NAMESPACE" --ignore-not-found
    err "Rollback complete."
}

sync_and_verify() {
    local src_pvc=$1 dst_pvc=$2 job_name=$3 log_file
    log_file="$LOG_DIR/${job_name}_$(date +%Y%m%d_%H%M%S).log"
    
    msg "Syncing $src_pvc -> $dst_pvc..."
    
    cat <<EOF | kubectl apply -f -
apiVersion: v1
kind: Pod
metadata:
  name: $job_name
  namespace: $NAMESPACE
spec:
  containers:
  - name: rsync
    image: $RSYNC_IMAGE
    command: ["sh", "-c", "rsync -avh --no-perms --no-owner --no-group --info=progress2 /src/ /dst/"]
    volumeMounts: [{name: src, mountPath: /src}, {name: dst, mountPath: /dst}]
  restartPolicy: Never
  volumes:
  - name: src
    persistentVolumeClaim: {claimName: $src_pvc}
  - name: dst
    persistentVolumeClaim: {claimName: $dst_pvc}
EOF

    kubectl wait --for=condition=Ready "pod/$job_name" -n "$NAMESPACE" --timeout=120s || rollback
    kubectl logs -f "$job_name" -n "$NAMESPACE" | tee "$log_file"

    local SRC_SIZE DST_SIZE SRC_COUNT DST_COUNT
    SRC_SIZE=$(kubectl exec "$job_name" -n "$NAMESPACE" -- du -sh /src | awk '{print $1}')
    DST_SIZE=$(kubectl exec "$job_name" -n "$NAMESPACE" -- du -sh /dst | awk '{print $1}')
    SRC_COUNT=$(kubectl exec "$job_name" -n "$NAMESPACE" -- sh -c "ls -1R /src | wc -l")
    DST_COUNT=$(kubectl exec "$job_name" -n "$NAMESPACE" -- sh -c "ls -1R /dst | wc -l")

    echo -e "METRIC\tSOURCE\tDEST\tMATCH\nSize\t$SRC_SIZE\t$DST_SIZE\t$([[ "$SRC_SIZE" == "$DST_SIZE" ]] && echo "✅" || echo "❌")\nFiles\t$SRC_COUNT\t$DST_COUNT\t$([[ "$SRC_COUNT" == "$DST_COUNT" ]] && echo "✅" || echo "❌")" | column -t -s $'\t'

    read -r -p "Proceed? (y/n): " CONFIRM
    [[ $CONFIRM != "y" ]] && rollback
    kubectl delete pod "$job_name" -n "$NAMESPACE"
}

# --- 2. Main Execution Entry Point ---

# Check dependencies before doing anything else
check_deps

mkdir -p "$LOG_DIR"

# Argument Parsing
for arg in "$@"; do
    case $arg in
        --version|-v) echo "kubectl-pvc-shrink $VERSION"; exit 0 ;;
        --help|-h) echo "Usage: kubectl pvc-shrink [--dry-run] [--no-check]"; exit 0 ;;
    esac
done

# Run Update Check (Pass arguments to function)
if [[ "$*" != *"--no-check"* ]]; then
    check_updates "$@"
fi

DRY_RUN=false
[[ "$*" == *"--dry-run"* ]] && DRY_RUN=true

# Selection Menus
TYPE=$(echo -e "deployment\nstatefulset" | fzf --header="Select Resource Type")
[[ -z "$TYPE" ]] && exit 0

SELECTED_RES=$(kubectl get "$TYPE" -A -o custom-columns="NAMESPACE:.metadata.namespace,NAME:.metadata.name" --no-headers | fzf --header="Select $TYPE")
[[ -z "$SELECTED_RES" ]] && exit 0

NAMESPACE=$(echo "$SELECTED_RES" | awk '{print $1}')
RES_NAME=$(echo "$SELECTED_RES" | awk '{print $2}')

PVC_NAME=$(kubectl get "$TYPE" "$RES_NAME" -n "$NAMESPACE" -o jsonpath='{.spec.template.spec.volumes[*].persistentVolumeClaim.claimName}' | tr ' ' '\n' | fzf --header="Select PVC")
[[ -z "$PVC_NAME" ]] && exit 0

CURRENT_SIZE=$(kubectl get pvc "$PVC_NAME" -n "$NAMESPACE" -o jsonpath='{.spec.resources.requests.storage}')
read -r -p "Current size: $CURRENT_SIZE. Enter New Size (e.g. 5Gi): " NEW_SIZE

if [ "$DRY_RUN" = true ]; then
    kubectl get pvc "$PVC_NAME" -n "$NAMESPACE" -o yaml | yq "del(.status, .metadata.uid, .metadata.resourceVersion, .metadata.creationTimestamp, .spec.volumeName) | .spec.resources.requests.storage = \"$NEW_SIZE\""
    exit 0
fi

ORIG_REPLICAS=$(kubectl get "$TYPE" "$RES_NAME" -n "$NAMESPACE" -o jsonpath='{.spec.replicas}')

trap rollback ERR
kubectl scale "$TYPE" "$RES_NAME" -n "$NAMESPACE" --replicas=0

kubectl get pvc "$PVC_NAME" -n "$NAMESPACE" -o yaml | yq ".metadata.name = \"$TEMP_PVC_NAME\" | del(.status, .metadata.uid, .metadata.resourceVersion, .metadata.creationTimestamp, .spec.volumeName)" | kubectl apply -f -

sync_and_verify "$PVC_NAME" "$TEMP_PVC_NAME" "shrink-to-temp"

kubectl get pvc "$PVC_NAME" -n "$NAMESPACE" -o yaml | yq "del(.status, .metadata.uid, .metadata.resourceVersion, .metadata.creationTimestamp, .spec.volumeName) | .spec.resources.requests.storage = \"$NEW_SIZE\" | .metadata.annotations |= with_entries(select(.key == \"volume.autoscaler.kubernetes.io/ignore\"))" | kubectl replace --force -f -

sync_and_verify "$TEMP_PVC_NAME" "$PVC_NAME" "shrink-back"

trap - ERR
kubectl scale "$TYPE" "$RES_NAME" -n "$NAMESPACE" --replicas="$ORIG_REPLICAS"
kubectl delete pvc "$TEMP_PVC_NAME" -n "$NAMESPACE"
msg "Shrink Successful!"