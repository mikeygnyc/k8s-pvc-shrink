#!/bin/bash
set -e

# --- 1. Constants & Functions (Defined First) ---
VERSION="v1.1.9"
UPDATE_URL="https://raw.githubusercontent.com/mikeygnyc/k8s-pvc-shrink/refs/heads/main/VERSION"
RAW_SCRIPT_URL="https://raw.githubusercontent.com/mikeygnyc/k8s-pvc-shrink/refs/heads/main/kubectl-pvcshrink"
TEMP_PVC_NAME="pvc-shrink-temp"
RSYNC_IMAGE="instrumentisto/rsync-ssh"
LOG_DIR="./shrink_logs"

# Use \033 for better compatibility across different terminals/shells
msg() { echo -e "\033[32m[INFO]\033[0m $1"; }
err() { echo -e "\033[31m[ERROR]\033[0m $1"; exit 1; }
highlight() { echo -e "\033[33m$1\033[0m"; }

# Pre-flight Dependency Check
check_deps() {
    local missing_deps=()
    for dep in kubectl fzf yq column curl; do
        if ! command -v "$dep" >/dev/null 2>&1; then
            missing_deps+=("$dep")
        fi
    done

    if [ ${#missing_deps[@]} -ne 0 ]; then
        echo -e "\033[31m[!] Missing Dependencies:\033[0m"
        for item in "${missing_deps[@]}"; do
            echo "  - $item"
        done
        echo -e "\nPlease install them (e.g., brew install fzf yq)."
        exit 1
    fi
}

check_updates() {
    msg "Checking for updates..."
    local REMOTE_VERSION
    # Fix SC2155: Separate declaration and assignment
    REMOTE_VERSION=$(curl -fL -sS --connect-timeout 2 -H "Cache-Control: no-cache" "$UPDATE_URL" | tr -d '[:space:]' || echo "$VERSION")

    # Basic sanitization to ensure we didn't get an HTML page
    if [[ "$REMOTE_VERSION" == *"html"* ]] || [[ -z "$REMOTE_VERSION" ]]; then
        REMOTE_VERSION="$VERSION"
    fi

    if [[ "$REMOTE_VERSION" != "$VERSION" ]]; then
        highlight "✨ A new version ($REMOTE_VERSION) is available! (Current: $VERSION)"
        read -r -p "Update and restart now? (y/n): " UPDATE_NOW
        if [[ "$UPDATE_NOW" == "y" ]]; then
            local SCRIPT_PATH
            SCRIPT_PATH=$(command -v kubectl-pvcshrink || echo "$0")
            local TEMP_FILE="/tmp/kubectl-pvcshrink-update"

            msg "Downloading update..."
            if curl -fL -sSH "Cache-Control: no-cache" "$RAW_SCRIPT_URL" -o "$TEMP_FILE"; then
                if [ -w "$SCRIPT_PATH" ]; then
                    mv "$TEMP_FILE" "$SCRIPT_PATH" && chmod +x "$SCRIPT_PATH"
                else
                    sudo mv "$TEMP_FILE" "$SCRIPT_PATH" && sudo chmod +x "$SCRIPT_PATH"
                fi
                msg "Update successful. Restarting..."
                exec "$SCRIPT_PATH" "$@"
            else
                err "Update download failed."
            fi
        fi
        echo "------------------------------------------------"
    fi
}

rollback() {
    echo -e "\n"
    msg "Rolling back..."
    kubectl scale "$TYPE" "$RES_NAME" -n "$NAMESPACE" --replicas="$ORIG_REPLICAS"
    kubectl delete pod shrink-to-temp shrink-back -n "$NAMESPACE" --ignore-not-found
    kubectl delete pvc "$TEMP_PVC_NAME" -n "$NAMESPACE" --ignore-not-found
    err "Rollback complete."
}

sync_and_verify() {
    local src_pvc=$1
    local dst_pvc=$2
    local job_name=$3
    local log_file
    log_file="$LOG_DIR/${job_name}_$(date +%Y%m%d_%H%M%S).log"
    
    local start_time
    start_time=$(date +%s)
    msg "Syncing $src_pvc -> $dst_pvc..."
    
    # Create the Sync Pod
    cat <<EOF | kubectl apply -f -
apiVersion: v1
kind: Pod
metadata:
  name: $job_name
  namespace: $NAMESPACE
spec:
  containers:
  - name: rsync
    image: $RSYNC_IMAGE
    command: ["sh", "-c", "rsync -avh --inplace --no-perms --no-owner --no-group --info=progress2 /src/ /dst/ && echo 'Sync Complete' && tail -f /dev/null"]
    volumeMounts: [{name: src, mountPath: /src}, {name: dst, mountPath: /dst}]
  restartPolicy: Never
  volumes:
  - name: src
    persistentVolumeClaim: {claimName: $src_pvc}
  - name: dst
    persistentVolumeClaim: {claimName: $dst_pvc}
EOF

    # Wait for Pod to be ready
    kubectl wait --for=condition=Ready "pod/$job_name" -n "$NAMESPACE" --timeout=120s || rollback
    
    # Stream logs with overwrite logic
    msg "Progress:"
    # Use tee to satisfy SC2034 and actually log the output
    kubectl logs -f "$job_name" -n "$NAMESPACE" | \
        stdbuf -oL tr '\r' '\n' | \
        tee "$log_file" | \
        sed '/Sync Complete/q' | \
        stdbuf -oL tr '\n' '\r'
    
    echo -e "\n"
    
    local end_time
    local duration
    end_time=$(date +%s)
    duration=$((end_time - start_time))

    msg "Verifying data integrity..."
    local SRC_SIZE DST_SIZE SRC_COUNT DST_COUNT
    
    # Verification (Container is kept alive by tail -f /dev/null)
    # Fix SC2155: Separated declaration and assignment
    SRC_SIZE=$(kubectl exec "$job_name" -n "$NAMESPACE" -- du -sh /src | awk '{print $1}')
    DST_SIZE=$(kubectl exec "$job_name" -n "$NAMESPACE" -- du -sh /dst | awk '{print $1}')
    SRC_COUNT=$(kubectl exec "$job_name" -n "$NAMESPACE" -- sh -c "ls -1R /src | wc -l")
    DST_COUNT=$(kubectl exec "$job_name" -n "$NAMESPACE" -- sh -c "ls -1R /dst | wc -l")

    # Final Summary Table
    echo -e "\n--- Sync Summary ---"
    echo -e "Duration:\t${duration} seconds"
    echo -e "METRIC\tSOURCE\tDEST\tMATCH"
    echo -e "Size\t$SRC_SIZE\t$DST_SIZE\t$([[ "$SRC_SIZE" == "$DST_SIZE" ]] && echo "✅" || echo "❌")"
    echo -e "Files\t$SRC_COUNT\t$DST_COUNT\t$([[ "$SRC_COUNT" == "$DST_COUNT" ]] && echo "✅" || echo "❌")" | column -t -s $'\t'
    echo -e "--------------------\n"

    read -r -p "Proceed with migration? (y/n): " CONFIRM
    [[ $CONFIRM != "y" ]] && rollback
    
    kubectl delete pod "$job_name" -n "$NAMESPACE" --wait=false >/dev/null 2>&1
}

# --- 2. Main Execution Entry Point ---

check_deps
mkdir -p "$LOG_DIR"

# Argument Parsing
for arg in "$@"; do
    case $arg in
        --version|-v) echo "kubectl-pvcshrink $VERSION"; exit 0 ;;
        --help|-h) echo "Usage: kubectl pvcshrink [--dry-run] [--no-check]"; exit 0 ;;
    esac
done

if [[ "$*" != *"--no-check"* ]]; then
    check_updates "$@"
fi

DRY_RUN=false
[[ "$*" == *"--dry-run"* ]] && DRY_RUN=true

TYPE=$(echo -e "deployment\nstatefulset" | fzf --header="Select Resource Type")
[[ -z "$TYPE" ]] && exit 0

SELECTED_RES=$(kubectl get "$TYPE" -A -o custom-columns="NAMESPACE:.metadata.namespace,NAME:.metadata.name" --no-headers | fzf --header="Select $TYPE")
[[ -z "$SELECTED_RES" ]] && exit 0

NAMESPACE=$(echo "$SELECTED_RES" | awk '{print $1}')
RES_NAME=$(echo "$SELECTED_RES" | awk '{print $2}')

PVC_NAME=$(kubectl get "$TYPE" "$RES_NAME" -n "$NAMESPACE" -o jsonpath='{.spec.template.spec.volumes[*].persistentVolumeClaim.claimName}' | tr ' ' '\n' | fzf --header="Select PVC")
[[ -z "$PVC_NAME" ]] && exit 0

CURRENT_SIZE=$(kubectl get pvc "$PVC_NAME" -n "$NAMESPACE" -o jsonpath='{.spec.resources.requests.storage}')
read -r -p "Current size: $CURRENT_SIZE. Enter New Size (e.g. 5Gi): " NEW_SIZE

if [ "$DRY_RUN" = true ]; then
    kubectl get pvc "$PVC_NAME" -n "$NAMESPACE" -o yaml | yq "del(.status, .metadata.uid, .metadata.resourceVersion, .metadata.creationTimestamp, .spec.volumeName) | .spec.resources.requests.storage = \"$NEW_SIZE\""
    exit 0
fi

ORIG_REPLICAS=$(kubectl get "$TYPE" "$RES_NAME" -n "$NAMESPACE" -o jsonpath='{.spec.replicas}')

trap rollback ERR
kubectl scale "$TYPE" "$RES_NAME" -n "$NAMESPACE" --replicas=0

msg "Creating staging PVC..."
kubectl get pvc "$PVC_NAME" -n "$NAMESPACE" -o yaml | yq '
  .metadata.name = "'"$TEMP_PVC_NAME"'" | 
  del(
    .status, 
    .metadata.uid, 
    .metadata.resourceVersion, 
    .metadata.creationTimestamp, 
    .metadata.annotations["pv.kubernetes.io/bind-completed"],
    .metadata.annotations["pv.kubernetes.io/bound-by-controller"],
    .spec.volumeName
  )' | kubectl apply -f -

msg "Waiting for $TEMP_PVC_NAME to bind..."
kubectl wait --for=jsonpath='{.status.phase}'=Bound pvc/"$TEMP_PVC_NAME" -n "$NAMESPACE" --timeout=120s || rollback

# 2. Sync Data to Staging
sync_and_verify "$PVC_NAME" "$TEMP_PVC_NAME" "shrink-to-temp"

# 3. Delete & Recreate original PVC with new size
kubectl get pvc "$PVC_NAME" -n "$NAMESPACE" -o yaml | yq "del(.status, .metadata.uid, .metadata.resourceVersion, .metadata.creationTimestamp, .spec.volumeName) | .spec.resources.requests.storage = \"$NEW_SIZE\" | .metadata.annotations |= with_entries(select(.key == \"volume.autoscaler.kubernetes.io/ignore\"))" | kubectl replace --force -f -

msg "Waiting for $PVC_NAME to re-bind at new size..."
kubectl wait --for=jsonpath='{.status.phase}'=Bound pvc/"$PVC_NAME" -n "$NAMESPACE" --timeout=120s || rollback

# 4. Sync Data back to original
sync_and_verify "$TEMP_PVC_NAME" "$PVC_NAME" "shrink-back"

trap - ERR
kubectl scale "$TYPE" "$RES_NAME" -n "$NAMESPACE" --replicas="$ORIG_REPLICAS"
kubectl delete pvc "$TEMP_PVC_NAME" -n "$NAMESPACE"
msg "Shrink Successful!"