#!/bin/bash
set -e

# --- 1. Constants & Functions ---
VERSION="v1.1.20"
UPDATE_URL="https://raw.githubusercontent.com/mikeygnyc/k8s-pvc-shrink/refs/heads/main/VERSION"
RAW_SCRIPT_URL="https://raw.githubusercontent.com/mikeygnyc/k8s-pvc-shrink/refs/heads/main/kubectl-pvcshrink"
TEMP_PVC_NAME="pvc-shrink-temp"
RSYNC_IMAGE="instrumentisto/rsync-ssh"
LOG_DIR="./shrink_logs"

msg() {
    echo -e "\033[32m[INFO]\033[0m $1"
}

err() {
    echo -e "\033[31m[ERROR]\033[0m $1"
    exit 1
}

highlight() {
    echo -e "\033[33m$1\033[0m"
}

version_gt() {
    test "$(printf '%s\n' "$@" | sort -V | head -n 1)" != "$1"
}

check_deps() {
    local missing_deps=()
    for dep in kubectl fzf yq column curl bc numfmt; do
        if ! command -v "$dep" >/dev/null 2>&1; then
            missing_deps+=("$dep")
        fi
    done
    
    if [[ ${#missing_deps[@]} -ne 0 ]]; then
        echo -e "\033[31m[!] Missing Dependencies:\033[0m"
        for item in "${missing_deps[@]}"; do
            echo "  - $item"
        done
        exit 1
    fi
}

check_updates() {
    local REMOTE_VERSION clean_remote clean_current SCRIPT_PATH TEMP_FILE
    REMOTE_VERSION=$(curl -fL -sS --connect-timeout 2 -H "Cache-Control: no-cache" "$UPDATE_URL" | tr -d '[:space:]' || echo "$VERSION")
    
    clean_remote="${REMOTE_VERSION#v}"
    clean_current="${VERSION#v}"

    if version_gt "$clean_remote" "$clean_current"; then
        highlight "✨ A new version ($REMOTE_VERSION) is available!"
        read -r -p "Update and restart now? (y/n): " UPDATE_NOW
        if [[ "$UPDATE_NOW" == "y" ]]; then
            SCRIPT_PATH=$(command -v kubectl-pvcshrink || echo "$0")
            TEMP_FILE="/tmp/pvcshrink-upd"
            if curl -fL -sSH "Cache-Control: no-cache" "$RAW_SCRIPT_URL" -o "$TEMP_FILE"; then
                mv "$TEMP_FILE" "$SCRIPT_PATH"
                chmod +x "$SCRIPT_PATH"
                msg "Update successful. Restarting..."
                exec "$SCRIPT_PATH" "$@"
            fi
        fi
    fi
}

rollback() {
    echo -e "\n"
    highlight "[CRITICAL] An error occurred. Attempting scale-up recovery..."
    kubectl scale "$TYPE" "$RES_NAME" -n "$NAMESPACE" --replicas="$ORIG_REPLICAS" || true
    msg "Workload scaled back. NOTE: '$TEMP_PVC_NAME' was NOT deleted to preserve data."
    err "Manual intervention required. Check PVC '$PVC_NAME' vs '$TEMP_PVC_NAME'."
}

sync_and_verify() {
    local src_pvc=$1 dst_pvc=$2 job_name=$3 log_file start_time end_time duration
    local SRC_SIZE DST_SIZE SRC_COUNT DST_COUNT size_match count_match CONFIRM
    
    log_file="$LOG_DIR/${job_name}_$(date +%Y%m%d_%H%M%S).log"
    start_time=$(date +%s)
    
    msg "Preparing sync Pod ($job_name)..."
    cat <<EOF | kubectl replace --force -f -
apiVersion: v1
kind: Pod
metadata:
  name: $job_name
  namespace: $NAMESPACE
spec:
  containers:
  - name: sync
    image: $RSYNC_IMAGE
    command: ["sh", "-c", "tail -f /dev/null"]
    volumeMounts:
    - name: src
      mountPath: /src
    - name: dst
      mountPath: /dst
  restartPolicy: Never
  volumes:
  - name: src
    persistentVolumeClaim: {claimName: $src_pvc}
  - name: dst
    persistentVolumeClaim: {claimName: $dst_pvc}
EOF

    kubectl wait --for=condition=Ready "pod/$job_name" -n "$NAMESPACE" --timeout=120s >/dev/null

    msg "Syncing data (Live Progress):"
    if ! kubectl exec "$job_name" -n "$NAMESPACE" -- \
        rsync -avh --inplace --no-perms --no-owner --no-group --info=progress2 /src/ /dst/ | tee "$log_file"; then
        highlight "⚠️ Rsync reported errors. Verify logs at $log_file"
    fi

    end_time=$(date +%s)
    duration=$((end_time - start_time))

    msg "Verifying integrity..."
    SRC_SIZE=$(kubectl exec "$job_name" -n "$NAMESPACE" -- du -sh /src 2> >(grep -v "Unknown stream id" >&2) | awk '{print $1}')
    DST_SIZE=$(kubectl exec "$job_name" -n "$NAMESPACE" -- du -sh /dst 2> >(grep -v "Unknown stream id" >&2) | awk '{print $1}')
    SRC_COUNT=$(kubectl exec "$job_name" -n "$NAMESPACE" -- sh -c "ls -1R /src 2> >(grep -v 'Unknown stream id' >&2) | wc -l")
    DST_COUNT=$(kubectl exec "$job_name" -n "$NAMESPACE" -- sh -c "ls -1R /dst 2> >(grep -v 'Unknown stream id' >&2) | wc -l")

    size_match="❌"
    [[ "$SRC_SIZE" == "$DST_SIZE" ]] && size_match="✅"
    
    count_match="❌"
    [[ "$SRC_COUNT" == "$DST_COUNT" ]] && count_match="✅"

    echo -e "\n--- Sync Summary ---\nDuration: ${duration}s"
    echo -e "METRIC\tSOURCE\tDEST\tMATCH\nSize\t$SRC_SIZE\t$DST_SIZE\t$size_match\nFiles\t$SRC_COUNT\t$DST_COUNT\t$count_match" | column -t -s $'\t'
    
    if [[ "$size_match" == "❌" ]]; then
        highlight "⚠️ WARNING: Data sizes do not match!"
    fi
    
    read -r -p "Proceed to next step? (y/n): " CONFIRM
    if [[ "$CONFIRM" != "y" ]]; then 
        rollback
    fi
    
    kubectl delete pod "$job_name" -n "$NAMESPACE" --wait=false >/dev/null 2>&1
}

# --- 2. Main Execution ---
check_deps
mkdir -p "$LOG_DIR"

DRY_RUN=false
SKIP_CHECK=false
for arg in "$@"; do
    case $arg in
        --dry-run) DRY_RUN=true ;;
        --no-check) SKIP_CHECK=true ;;
    esac
done

[[ "$SKIP_CHECK" = false ]] && check_updates "$@"

TYPE=$(echo -e "deployment\nstatefulset" | fzf --header="Select Resource Type")
[[ -z "$TYPE" ]] && exit 0

SELECTED_RES=$(kubectl get "$TYPE" -A -o custom-columns="NAMESPACE:.metadata.namespace,NAME:.metadata.name" --no-headers | fzf --header="Select $TYPE")
[[ -z "$SELECTED_RES" ]] && exit 0

NAMESPACE=$(echo "$SELECTED_RES" | awk '{print $1}')
RES_NAME=$(echo "$SELECTED_RES" | awk '{print $2}')

kubectl delete pod shrink-to-temp shrink-back -n "$NAMESPACE" --ignore-not-found --wait=false >/dev/null 2>&1

PVC_NAME=$(kubectl get "$TYPE" "$RES_NAME" -n "$NAMESPACE" -o jsonpath='{.spec.template.spec.volumes[*].persistentVolumeClaim.claimName}' | tr ' ' '\n' | fzf --header="Select PVC")
[[ -z "$PVC_NAME" ]] && exit 0

CURRENT_SIZE=$(kubectl get pvc "$PVC_NAME" -n "$NAMESPACE" -o jsonpath='{.spec.resources.requests.storage}')
CURRENT_UNIT=${CURRENT_SIZE//[0-9.]/}

ACTIVE_POD=$(kubectl get pods -n "$NAMESPACE" --field-selector=status.phase=Running -o json | yq ".items[] | select(.spec.volumes[].persistentVolumeClaim.claimName == \"$PVC_NAME\") | .metadata.name" | head -n 1)

if [[ -n "$ACTIVE_POD" ]]; then
    # Fixed: Using yq to find the mount path to avoid kubectl jsonpath filter bugs
    MOUNT_NAME=$(kubectl get pod "$ACTIVE_POD" -n "$NAMESPACE" -o json | yq -r ".spec.volumes[] | select(.persistentVolumeClaim.claimName == \"$PVC_NAME\") | .name")
    MOUNT_PATH=$(kubectl get pod "$ACTIVE_POD" -n "$NAMESPACE" -o json | yq -r ".spec.containers[].volumeMounts[] | select(.name == \"$MOUNT_NAME\") | .mountPath" | head -n 1)

    msg "Calculating usage on $MOUNT_PATH..."
    SOURCE_BYTES=$(kubectl exec -n "$NAMESPACE" "$ACTIVE_POD" -- du -sb "$MOUNT_PATH" | awk '{print $1}')
    SOURCE_HUMAN=$(numfmt --to=iec-i --suffix=B --format="%.2f" "$SOURCE_BYTES")
    TEN_PERCENT_BUFFER=$(echo "$SOURCE_BYTES * 1.1" | bc | cut -d'.' -f1)
    MIN_REC=$(numfmt --to=iec-i --suffix=B --format="%.2f" "$TEN_PERCENT_BUFFER")
    
    echo -e "Current: $CURRENT_SIZE | Usage: $SOURCE_HUMAN | Min Rec (+10%): $MIN_REC"
    
    while true; do
        read -r -p "Enter New Size (e.g., 50 or 50Gi): " USER_INPUT
        [[ -z "$USER_INPUT" ]] && continue
        
        if [[ "$USER_INPUT" =~ ^[0-9.]+$ ]]; then
            NEW_SIZE="${USER_INPUT}${CURRENT_UNIT}"
        else
            NEW_SIZE="$USER_INPUT"
        fi
        
        CLEAN_NEW_SIZE=${NEW_SIZE//i/}
        NEW_SIZE_BYTES=$(numfmt --from=iec "$CLEAN_NEW_SIZE")

        if [[ "$SOURCE_BYTES" -gt "$NEW_SIZE_BYTES" ]]; then
            echo -e "\033[31mError: New size ($NEW_SIZE) is smaller than data ($SOURCE_HUMAN)!\033[0m"
            continue
        elif [[ "$TEN_PERCENT_BUFFER" -gt "$NEW_SIZE_BYTES" ]]; then
            read -r -p "Warning: Less than 10% overhead. Continue? (y/n): " WC
            [[ "$WC" != "y" ]] && continue
        fi
        break
    done
else
    read -r -p "No pod running. Enter New Size (e.g., 10Gi): " NEW_SIZE
fi

if [[ "$DRY_RUN" = true ]]; then 
    kubectl get pvc "$PVC_NAME" -n "$NAMESPACE" -o yaml | yq ".spec.resources.requests.storage = \"$NEW_SIZE\""
    exit 0
fi

ORIG_REPLICAS=$(kubectl get "$TYPE" "$RES_NAME" -n "$NAMESPACE" -o jsonpath='{.spec.replicas}')
trap rollback ERR

msg "Scaling down $TYPE/$RES_NAME..."
kubectl scale "$TYPE" "$RES_NAME" -n "$NAMESPACE" --replicas=0
kubectl wait --for=delete pod -l "app.kubernetes.io/name=$RES_NAME" -n "$NAMESPACE" --timeout=120s || true

msg "Creating staging PVC..."
kubectl get pvc "$PVC_NAME" -n "$NAMESPACE" -o yaml | yq '.metadata.name = "'"$TEMP_PVC_NAME"'" | del(.status, .metadata.uid, .metadata.resourceVersion, .metadata.creationTimestamp, .metadata.annotations["pv.kubernetes.io/bind-completed"], .metadata.annotations["pv.kubernetes.io/bound-by-controller"], .spec.volumeName)' | kubectl apply -f -
kubectl wait --for=jsonpath='{.status.phase}'=Bound pvc/"$TEMP_PVC_NAME" -n "$NAMESPACE" --timeout=300s

sync_and_verify "$PVC_NAME" "$TEMP_PVC_NAME" "shrink-to-temp"

msg "Recreating original PVC at $NEW_SIZE..."
kubectl delete pvc "$PVC_NAME" -n "$NAMESPACE" --wait=true
kubectl get pvc "$TEMP_PVC_NAME" -n "$NAMESPACE" -o yaml | yq '.metadata.name = "'"$PVC_NAME"'" | .spec.resources.requests.storage = "'"$NEW_SIZE"'" | del(.status, .metadata.uid, .metadata.resourceVersion, .metadata.creationTimestamp, .metadata.annotations["pv.kubernetes.io/bind-completed"], .metadata.annotations["pv.kubernetes.io/bound-by-controller"], .spec.volumeName)' | kubectl apply -f -
kubectl wait --for=jsonpath='{.status.phase}'=Bound pvc/"$PVC_NAME" -n "$NAMESPACE" --timeout=300s

sync_and_verify "$TEMP_PVC_NAME" "$PVC_NAME" "shrink-back"

trap - ERR
msg "Restoring workload..."
kubectl scale "$TYPE" "$RES_NAME" -n "$NAMESPACE" --replicas="$ORIG_REPLICAS"
kubectl rollout status "$TYPE/$RES_NAME" -n "$NAMESPACE" --timeout=300s

msg "Verifying Pod Readiness..."
sleep 2
kubectl wait --for=condition=Ready pods -n "$NAMESPACE" -l "app.kubernetes.io/name=$RES_NAME" --timeout=300s || \
kubectl wait --for=condition=Ready pods -n "$NAMESPACE" -l "app=$RES_NAME" --timeout=300s || true

msg "Shrink Complete. Cleaning up temporary volume..."
kubectl delete pvc "$TEMP_PVC_NAME" -n "$NAMESPACE"
msg "Success!"